---
import OrganizerCard from "./OrganizerCard.astro";
const { title, description, organizer } = Astro.props;
---

<h1 class="text-4xl font-bold my-8">{title}</h1>
<p>{description}</p>
<OrganizerCard
  name={organizer.name}
  icon={organizer.icon}
  organization={organizer.organization}
  profile={organizer.profile}
/>